<EditForm
    class="modal"
    Model="@profilModel"
    FormName="SaveProfil"
    id="createProfileModal"
    OnValidSubmit="saveProfil">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title">Nouveau profil</h6>
                <button type="button" class="btn-close cancelBtn"></button>
            </div>
            <div class="modal-body">
                <div class="row gy-3">
                    <div class="col-xl-12">
                        <label for="profil-name" class="form-label">
                            Nom utilisateur
                        </label>
                        <InputText
                            class="form-control"
                            id="profil-name"
                            @bind-Value="profilModel.UserName"
                            placeholder="Nom utilisateur" />
                    </div>
                    <div class="col-xl-12">
                        <label for="AG-utilisateur" class="form-label">
                            AG-utilisateur
                        </label>
                        <InputText
                            class="form-control"
                            id="utilisateur-AG"
                            @bind-Value="profilModel.Userag"
                            placeholder="AG-utilisateur" />
                    </div>
                    <div class="col-xl-12">
                        <label for="email" class="form-label">
                            Email utilisateur
                        </label>
                        <InputText
                            type="email"
                            class="form-control"
                            id="email"
                            @bind-Value="profilModel.Email"
                            placeholder="Email utilisateur" />
                    </div>
                    <div class="col-xl-12">
                        <label for="type-profil" class="form-label">
                            Type de profil
                        </label>
                        <InputSelect @bind-Value="profilModel.TypeProfile" class="form-select">
                            <option selected disabled>
                                Selectionnez un type de profil
                            </option>
                            @foreach (EnumProfil ep in Enum.GetValues(typeof(EnumProfil)))
                            {
                                <option value="@ep">
                                @ep.ToString()
                                </option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-xl-12">
                        <label for="user-status" class="form-label">
                            Statut du profil
                        </label>
                        <InputSelect @bind-Value="profilModel.Status" class="form-select">
                            @foreach (EnumStatut es in Enum.GetValues(typeof(EnumStatut)))
                            {
                                <option value="@es">
                                @es.ToString()
                                </option>
                            }
                        </InputSelect>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light cancelBtn">
                    Annuler
                </button>
                <button
                    id="
                    submitBtn
                    type="
                    submit
                    class="btn btn-success">
                    Enregistrer
                </button>
            </div>
        </div>
    </div>
</EditForm>
