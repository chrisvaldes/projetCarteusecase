 
@page "/profil" 
@rendermode InteractiveServer

<div class="d-flex align-items-center justify-content-between page-header-breadcrumb flex-wrap gap-2">
    <div >
        <nav>
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item fw-bold"> <a href="javascript:void(0);"> Gestion des utilisateurs </a> </li>
                <i class="ri-arrow-right-s-line side-menu__angle"></i>
                <li class="breadcrumb-item  " >Liste des utilisateurs</li>
            </ol>
        </nav>
        
    </div>
    <button class="btn btn-primary open-modal-btn" id="openProfileModalBtn">
        <i class="fa-solid fa-plus me-1 fw-medium align-middle"></i>Nouveau utilisateur
    </button>
</div>
 


<div class="row d-flex align-items-center justify-content-center">
    <div class="col-xxl-12">
        <div class="card custom-card">
            <div class="card-header d-flex align-items-center justify-content-between">
                <div class="card-title"> Liste des utilisateurs </div> 
                            
                <div class="d-block">
                    <div class="position-relative">

                        <input type="text"
                               id="searchInput"
                               class="form-control pe-5"
                               placeholder="Rechercher un utilisateur...">

                        <!-- Bouton clear -->
                        <span id="clearSearch"
                              class="position-absolute top-50 end-0 translate-middle-y me-3"
                              style="cursor:pointer; display:none;">

                            <i class="fa-solid fa-xmark text-muted"></i>

                        </span>

                    </div>

                    <div class="d-flex align-items-end justify-content-end  mt-1">
                        <small id="resultCount" class="text-muted mt-1"></small>
                    </div>
                </div>
                 
            </div>
            <div class="card-body">

                <div class="card-body">
                    <div class="table-responsive">
                        <table id="usersTable" class="table table-hover text-nowrap table-bordered">
                            <thead>
                                <tr>
                                    <th class="text-center" scope="col">P.No</th>
                                    <th class="text-center" scope="col">Nom & Prénom</th>
                                    <th class="text-center" scope="col">AG Utilisateur</th>
                                    <th class="text-center" scope="col">Email</th>
                                    <th class="text-center" scope="col">Type Profil</th>
                                    <th class="text-center" scope="col">Status</th>
                                    <th class="text-center" scope="col">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @* @if (!Model.Any())
                                { *@
                                    <tr class="text-center text-danger">
                                        <td colspan="6">Aucun profil utilisateur enregistré!!!</td>
                                    </tr>
                                @* }
                                else
                                { *@
                                    @* foreach (var profil in Model)
                                    { *@
                                        <tr>
                                            <td class="text-center">index</td>
                                            <td class="text-center">profil.UserName</td>
                                            <td class="text-center">profil.Userag</td>
                                            <td class="text-center">profil.Email</td>

                                            <td class="text-left">
                                                <span class="badge bg-primary-transparent">
                                                    profil.TypeProfile
                                                </span>
                                            </td>

                                            
                                            <td class="text-center">
                                                <span class="badge (profil.Status == "Actif" ? "bg-success" : "bg-warning-transparent")">
                                                    profil.Status
                                                </span>
                                                 
                                            </td>

                                            <td class="text-center">
                                                <div class="btn-list">
                                                    <a class="btn btn-icon rounded-pill btn-sm btn-secondary-light openUpdateProfileModalBtn"
                                                       data-id="profil.Id"
                                                       href="javascript:void(0);"
                                                       data-bs-toggle="tooltip"
                                                       data-bs-placement="top"
                                                       title="Edit">
                                                        <i class="fa-solid fa-pencil"></i>
                                                    </a>

                                                    <a href="javascript:void(0);"
                                                       onclick="showDeleteProfile('profil.Id')"
                                                       data-bs-toggle="tooltip"
                                                       data-bs-placement="top"
                                                       title="Delete"
                                                       class="btn btn-icon rounded-pill btn-sm btn-danger-light">
                                                        <i class="fa-solid fa-trash"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>

                                        @* index++; *@
                                @*     }
                                } *@
                            </tbody>
                        </table>
                        <div class="card-footer">

                            <div class="d-flex align-items-center">

                                <div>
                                    <small id="resultCount" class="text-muted"></small>
                                </div>

                                <div class="ms-auto">

                                    <nav aria-label="Page navigation"
                                         class="pagination-style-4">

                                        <ul class="pagination mb-0" id="paginationContainer">

                                            <!-- PREV -->
                                            <li class="page-item" id="prevPageItem">

                                                <a class="page-link"
                                                   href="javascript:void(0);"
                                                   id="prevPage">

                                                    Prec

                                                </a>

                                            </li>

                                            <!-- NUMEROS -->
                                            <span id="pageNumbers"
                                                  class=" "></span>

                                            <!-- NEXT -->
                                            <li class="page-item" id="nextPageItem">

                                                <a class="page-link text-primary"
                                                   href="javascript:void(0);"
                                                   id="nextPage">

                                                    Suiv

                                                </a>

                                            </li>

                                        </ul>

                                    </nav>

                                </div>

                            </div>

                        </div>

                    </div>
                </div>
                 
            </div>
             
        </div>
    </div>


    @* Modal de creation de profil *@

    <EditForm class="modal" Model="@profilModel" FormName="SaveProfil" id="createProfileModal" OnValidSubmit="saveProfil">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title">Nouveau profil</h6> <button type="button" class="btn-close cancelBtn" ></button>
                </div>
                <div class="modal-body">
                    <div class="row gy-3">
                         
                        <div class="col-xl-12">
                            <label for="profil-name" class="form-label">Nom utilisateur</label>
                            <InputText class="form-control" id="profil-name" @bind-Value="profilModel.UserName" placeholder="Nom utilisateur" />
                        </div>
                       
                        <div class="col-xl-12">
                            <label for="AG-utilisateur" class="form-label">AG-utilisateur</label>
                            <InputText class="form-control" id="utilisateur-AG" @bind-Value="profilModel.Userag" placeholder="AG-utilisateur" />    
                        </div>
                        <div class="col-xl-12">
                            <label for="email" class="form-label">Email utilisateur</label>
                            <InputText type="email" class="form-control" id="email" @bind-Value="profilModel.Email"  placeholder="Email utilisateur" /> 
                        </div>
                        <div class="col-xl-12">
                            <label for="type-profil" class="form-label">Type de profil</label>
                            <InputSelect @bind-Value="profilModel.TypeProfile" class="form-select">
                                <option selected disabled>Selectionnez un type de profil</option>
                                @foreach (EnumProfil ep in Enum.GetValues(typeof(EnumProfil)))
                                {
                                    <option value="@ep">@ep.ToString()</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="col-xl-12">
                            <label for="user-status" class="form-label">Statut du profil</label>
                            <InputSelect @bind-Value="profilModel.Status" class="form-select">
                                @foreach (EnumStatut es in Enum.GetValues(typeof(EnumStatut)))
                                {
                                    <option value="@es">@es.ToString()</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light cancelBtn">
                        Annuler
                    </button>
                    <button id="submitBtn" type="submit" class="btn btn-success">
                        Enregistrer
                    </button>
                </div>
            </div>
        </div>
    </EditForm>


</div>


@* Modal de mofification de profil *@

<form class="modal" id="updateProfileModal" >
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title">Mise à jour du profil</h6> <button type="button" class="btn-close cancelBtn" ></button>
            </div>
            <div class="modal-body">
                <div class="row gy-3">

                    <input type="text" class="form-control" id="profileId" name="Id"  style="display : none">

                    <div class="col-xl-12">
                        <label for="Username" class="form-label">Nom utilisateur</label>
                        <input type="text" class="form-control" id="Username" name="Username" placeholder="Nom utilisateur">
                    </div>

                    <div class="col-xl-12">
                        <label for="Userag" class="form-label">AG-utilisateur</label>
                        <input type="text" class="form-control" id="Userag" name="Userag" placeholder="AG-utilisateur">
                    </div>
                    <div class="col-xl-12">
                        <label for="Email" class="form-label">Email utilisateur</label>
                        <input type="email" class="form-control" id="Email" name="Email" placeholder="Email utilisateur">
                    </div>
                    <div class="col-xl-12">
                        <label for="TypeProfileString" class="form-label">Type de profil</label>
                        <select name="TypeProfileString" id="TypeProfileString" class="form-select">
                            <option selected="" disabled>Selectionnez un type de profil</option>
                            <option value="SUPER_ADMIN">Super Administrateur</option>
                            <option value="ADMIN">Administrateur</option>
                            <option value="MON_OFFICER">Monétique Officer</option>
                            <option value="MON_MANAGER">Monétique Manager</option>
                            <option value="COMPTABLE">Comptable</option>
                        </select>
                    </div>
                    <div class="col-xl-12">
                        <label for="Status" class="form-label">Statut du profil</label>
                        <select name="Status" id="Status" class="form-select">
                            <option value="" disabled>Selectionnez un status</option>
                            <option value="Actif">Actif</option>
                            <option value="Inactif">Inactif</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-light cancelBtn">
                    Annuler
                </button> <button id="submitBtn" type="submit"  class="btn btn-success">
                    Modifier
                </button>
            </div>
        </div>
    </div>
</form>
 
 
